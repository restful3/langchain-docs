# =====================================================================
# 2주차 Deep Agent 발표 — 실행 스크립트용 환경변수 샘플
# 사용법: 이 파일을 .env 로 복사한 뒤 빈 값을 채운다.
#   cp .env_sample .env
# =====================================================================

# --- OpenAI 호환 API ---------------------------------------------------
# 1) OpenAI 직접: OPENAI_API_KEY 만 채우고 OPENAI_BASE_URL 은 비운다.
# 2) OpenAI 호환 프록시: 둘 다 채운다.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# 사용할 모델 (provider:model 의 model 부분).
DEEPAGENT_MODEL=gpt-4o-mini
