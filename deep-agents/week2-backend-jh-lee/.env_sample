# =====================================================================
# 1주차 Deep Agent 발표 — 실행 스크립트용 환경변수 샘플
# 사용법: 이 파일을 .env 로 복사한 뒤 빈 값에 채워 넣는다.
#   cp .env_sample .env
# =====================================================================

# --- OpenAI 호환 API ---------------------------------------------------
# 1) OpenAI 직접: OPENAI_API_KEY 만 채우고 OPENAI_BASE_URL 은 비운다.
# 2) OpenAI 호환 프록시 (예: clipproxyapi): 둘 다 채운다.
OPENAI_API_KEY=
OPENAI_BASE_URL=
# 예: clipproxyapi 로컬 -> http://localhost:8317/v1

# 사용할 모델 (provider:model 의 model 부분).
# - OpenAI 직접: gpt-4o-mini, gpt-4o, gpt-5 ...
# - clipproxyapi: 프록시가 노출하는 식별자 (예: gpt-5.5)
DEEPAGENT_MODEL=gpt-4o-mini

# --- Tavily 검색 (01_quickstart_research_agent.py 에서만 필수) -----------
# https://tavily.com/ 에서 API 키 발급
TAVILY_API_KEY=

# --- Ollama (03_model_object_ollama.py 에서만 사용) ---------------------
# 모델은 미리 'ollama pull <name>' 으로 받아둔다.
OLLAMA_MODEL=llama3.1
